[
  {
    "name": "cornerstone-backend-container",
    "image": "055533306852.dkr.ecr.eu-west-1.amazonaws.com/cornerstone",
    "cpu": 256,
    "memory": 512,
    "essential": true,
    "portMappings": [
      {
        "containerPort": 8000,
        "hostPort": 8000
      }
    ],
    "mountPoints": [
      {
        "sourceVolume": "uploads",
        "containerPath": "/app/uploads",
        "readOnly": false
      }
    ],
    "environment": [
      {
        "name": "SERVICE_TYPE",
        "value": "backend"
      }
    ],
    "secrets": [
      {
        "name": "DATABASE_URL",
        "valueFrom": "${secret_arn}:DATABASE_URL::"
      },
      {
        "name": "JWT_SECRET",
        "valueFrom": "${secret_arn}:JWT_SECRET::"
      },
       {
        "name": "JWT_REFRESH_SECRET",
        "valueFrom": "${secret_arn}:JWT_REFRESH_SECRET::"
      },
       {
        "name": "FRONTEND_URL",
        "valueFrom": "${secret_arn}:FRONTEND_URL::"
      },
       {
        "name": "PORT",
        "valueFrom": "${secret_arn}:PORT::"
      },
       {
        "name": "NODE_ENV",
        "valueFrom": "${secret_arn}:NODE_ENV::"
      },
       {
        "name": "MAILJET_API_PUBLIC_KEY",
        "valueFrom": "${secret_arn}:MAILJET_API_PUBLIC_KEY::"
      },
       {
        "name": "MAILJET_API_PRIVATE_KEY",
        "valueFrom": "${secret_arn}:MAILJET_API_PRIVATE_KEY::"
      },
       {
        "name": "ADMIN_EMAIL_ADDRESS",
        "valueFrom": "${secret_arn}:ADMIN_EMAIL_ADDRESS::"
      },
       {
        "name": "SENDER_EMAIL_ADDRESS",
        "valueFrom": "${secret_arn}:SENDER_EMAIL_ADDRESS::"
      },
       {
        "name": "SUPPORT_EMAIL_ADDRESS",
        "valueFrom": "${secret_arn}:SUPPORT_EMAIL_ADDRESS::"
      },
       {
        "name": "FW_SECRET_HASH",
        "valueFrom": "${secret_arn}:FW_SECRET_HASH::"
      },
       {
        "name": "SUPPORT_PHONE_NUMBER",
        "valueFrom": "${secret_arn}:SUPPORT_PHONE_NUMBER::"
      },
       {
        "name": "CLOUDFLARE_ACCOUNT_ID",
        "valueFrom": "${secret_arn}:CLOUDFLARE_ACCOUNT_ID::"
      },
       {
        "name": "CLOUDFLARE_ACCESS_KEY_ID",
        "valueFrom": "${secret_arn}:CLOUDFLARE_ACCESS_KEY_ID::"
      },
       {
        "name": "CLOUDFLARE_SECRET_ACCESS_KEY",
        "valueFrom": "${secret_arn}:CLOUDFLARE_SECRET_ACCESS_KEY::"
      },
       {
        "name": "CLOUDFLARE_BUCKET_NAME",
        "valueFrom": "${secret_arn}:CLOUDFLARE_BUCKET_NAME::"
      },
       {
        "name": "CLOUDFLARE_PUBLIC_URL",
        "valueFrom": "${secret_arn}:CLOUDFLARE_PUBLIC_URL::"
      },
       {
        "name": "AWS_REGION",
        "valueFrom": "${secret_arn}:AWS_REGION::"
      },
       {
        "name": "AWS_ACCESS_KEY_ID",
        "valueFrom": "${secret_arn}:AWS_ACCESS_KEY_ID::"
      },
       {
        "name": "AWS_SECRET_ACCESS_KEY",
        "valueFrom": "${secret_arn}:AWS_SECRET_ACCESS_KEY::"
      },
       {
        "name": "AWS_S3_BUCKET",
        "valueFrom": "${secret_arn}:AWS_S3_BUCKET::"
      },
      {
        "name": "CLOUDFRONT_BASE_URL",
        "valueFrom": "${secret_arn}:CLOUDFRONT_BASE_URL::"
      },
      {
        "name": "FLUTTERWAVE_SECRET_KEY",
        "valueFrom": "${secret_arn}:FLUTTERWAVE_SECRET_KEY::"
      }
    ],
    "user": "0",
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/backend-task-family",
        "awslogs-region": "eu-west-1",
        "awslogs-stream-prefix": "ecs"
      }
    }
  }
]